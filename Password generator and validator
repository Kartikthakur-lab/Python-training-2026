import random
import string

def generate_password():
    ch = string.ascii_letters + string.digits + string.punctuation

    password = ""

    for i in range(8):
        password = password + random.choice(ch)

    return password


def check_password(password):

    if len(password) < 8:
        raise Exception("Password must be 8 characters")

    if not any(i.isupper() for i in password):
        raise Exception("Add uppercase letter")

    if not any(i.isdigit() for i in password):
        raise Exception("Add number")

    if not any(i in string.punctuation for i in password):
        raise Exception("Add special character")

    print("Strong password")


try:
    print("Generated Password:", generate_password())

    p = input("Enter your password: ")

    check_password(p)

except Exception as e:
    print("Error:", e)
